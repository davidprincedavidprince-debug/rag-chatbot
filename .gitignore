# ── FAISS index (rebuilt on deployment, never commit binary blobs) ──
faiss_index/

# ── Python cache ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ── Virtual environments ─────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── Streamlit secrets (contains your API key) ────────────────────────
.streamlit/secrets.toml

# ── OS clutter ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor noise ─────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Test / scratch files ─────────────────────────────────────────────
test.py
